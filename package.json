{
  "name": "ghost-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "varlock run -- next dev",
    "build": "varlock run -- next build",
    "start": "varlock run -- next start",
    "lint": "varlock run -- eslint",
    "db:generate": "varlock run -- prisma generate",
    "db:migrate": "varlock run -- prisma migrate dev",
    "db:studio": "varlock run -- prisma studio",
    "prepare": "simple-git-hooks",
    "trigger:dev": "varlock run -- npx trigger.dev@4.4.5 dev"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write --no-errors-on-unmatched",
      "eslint --fix"
    ],
    "*.json": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.71",
    "@base-ui/react": "^1.4.1",
    "@clerk/nextjs": "^7.3.1",
    "@clerk/themes": "^2.4.57",
    "@liveblocks/client": "^3.19.0",
    "@liveblocks/node": "^3.19.0",
    "@liveblocks/react": "^3.19.0",
    "@liveblocks/react-flow": "^3.19.0",
    "@liveblocks/react-ui": "^3.19.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "@trigger.dev/build": "^4.4.5",
    "@trigger.dev/react-hooks": "^4.4.5",
    "@trigger.dev/sdk": "^4.4.5",
    "@varlock/nextjs-integration": "^1.1.0",
    "@vercel/blob": "^2.3.3",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.177",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "varlock": "^1.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "lint-staged": "^17.0.2",
    "prisma": "^7.8.0",
    "shadcn": "^4.7.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
